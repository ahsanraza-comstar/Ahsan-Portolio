# --- Security ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-random-hex

# --- Admin login ---
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-this-strong-password

# --- Database ---
# Local dev: sqlite:///./portfolio.db
# Railway with persistent volume mounted at /data: sqlite:////data/portfolio.db
DATABASE_URL=sqlite:///./portfolio.db

# --- CORS (comma-separated, no trailing slash) ---
ALLOWED_ORIGINS=http://localhost:5173,https://ahsanraza.dev,https://www.ahsanraza.dev

# --- SMTP (Gmail App Password recommended) ---
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# --- API docs (set to "true" only in dev) ---
DOCS_ENABLED=false
